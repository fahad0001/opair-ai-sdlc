{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ai-sdlc.dev/schemas/prompt.schema.json",
  "title": "Vendor-neutral prompt definition",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "description", "body"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "category": {
      "type": "string",
      "enum": ["sdlc", "review", "refactor", "test", "docs", "ops", "security"]
    },
    "tags": { "type": "array", "items": { "type": "string" } },
    "input_schema": {
      "type": "object",
      "description": "JSON-schema for arguments expected from the user."
    },
    "tools": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Optional tool allow-list (vendor-specific subset)."
    },
    "model_hint": { "type": "string" },
    "body": {
      "type": "string",
      "minLength": 1,
      "description": "The prompt body (Markdown)."
    }
  }
}
